# Copy to .env.local and fill in OPENROUTER_API_KEY.
# Baseline calls Claude models through OpenRouter (OpenAI-compatible API).

# Required — your OpenRouter key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Default model — free tier. Handles PDF parsing and copy generation.
# Free options that work well: google/gemini-2.0-flash-exp:free
#                               meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# Per-job overrides — uncomment to use a different model per task.
# If you want higher-quality nudge copy, point COPY at a paid model.
# OPENROUTER_MODEL_PARSE=google/gemini-2.0-flash-exp:free
# OPENROUTER_MODEL_COPY=anthropic/claude-sonnet-4-5

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ─── Resend (real nudge email sends) ────────────────────────────────────────
# Free tier: 100 emails/day, 3000/month. Get one at https://resend.com/api-keys
# Without this set, /api/send-nudge returns 503 + a friendly "config required"
# message so the preview UI can show a hint instead of crashing.
RESEND_API_KEY=

# Optional. Defaults to "Baseline <onboarding@resend.dev>" (Resend's shared
# sender, no domain verification needed). To send from your own domain,
# verify it in the Resend dashboard then set e.g.:
#   RESEND_FROM_ADDRESS=Baseline <hello@your-domain.com>
# RESEND_FROM_ADDRESS=
